{
  "manifest_version": 3,
  "name": "Tab Triage AI",
  "version": "0.4.0",
  "description": "Group open tabs by intent, summarize each group, and clean up stale and duplicate tabs. Bring your own AI provider key.",
  "homepage_url": "https://github.com/shpwrck/Tab-Triage-AI",
  "author": "Tab Triage AI",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "windows",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*",
    "https://api.groq.com/*",
    "https://api.together.xyz/*",
    "https://api.fireworks.ai/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://api.notion.com/*",
    "https://extensionpay.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://extensionpay.com/*"],
      "js": ["lib/ExtPay.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Tab Triage AI",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "options_page": "options/options.html",
  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },
  "commands": {
    "open-popup": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open Tab Triage AI"
    },
    "triage-now": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Triage the current window now"
    },
    "search-tabs": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Search across all open tabs and saved sessions"
    }
  }
}
